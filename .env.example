# FastAPI runtime
PYTHONPATH=src
MODEL_ARTIFACTS_DIR=data/model
SCOUTING_CLEAN_DATASET_PATH=data/model/champion_players_clean.parquet
SCOUTING_API_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5500,http://127.0.0.1:5500
SCOUTING_STRICT_ARTIFACTS=0
SCOUTING_ENABLE_EXPERIMENTAL_NLP_ROUTES=0
SCOUTING_API_BASE=http://127.0.0.1:8000
SCOUTING_DATABASE_URL=
SCOUTING_TEAM_MODE=0
SCOUTING_SESSION_COOKIE_NAME=scoutml_session
SCOUTING_SESSION_SECRET=change-me-before-production
SCOUTING_INVITE_TOKEN_TTL_HOURS=72
SCOUTING_SESSION_SECURE_COOKIE=0

# Core market-value artifacts
SCOUTING_TEST_PREDICTIONS_PATH=data/model/champion_predictions_2024-25.csv
SCOUTING_VAL_PREDICTIONS_PATH=data/model/champion_predictions_2024-25_val.csv
SCOUTING_METRICS_PATH=data/model/champion_predictions_2024-25.metrics.json
SCOUTING_MODEL_MANIFEST_PATH=data/model/model_manifest.json
SCOUTING_BENCHMARK_REPORT_PATH=data/model/reports/market_value_benchmark_report.json
SCOUTING_WATCHLIST_PATH=data/model/scout_watchlist.jsonl
SCOUTING_DECISIONS_PATH=data/model/scout_decisions.jsonl

# Optional dual-role artifact overrides
SCOUTING_VALUATION_TEST_PREDICTIONS_PATH=
SCOUTING_VALUATION_VAL_PREDICTIONS_PATH=
SCOUTING_VALUATION_METRICS_PATH=
SCOUTING_FUTURE_SHORTLIST_TEST_PREDICTIONS_PATH=
SCOUTING_FUTURE_SHORTLIST_VAL_PREDICTIONS_PATH=
SCOUTING_FUTURE_SHORTLIST_METRICS_PATH=

# Optional market-value runtime tuning
SCOUTING_ENABLE_RESIDUAL_CALIBRATION=0
SCOUTING_CALIBRATION_MIN_SAMPLES=30

# Optional similarity resources
PLAYER_FAISS_INDEX_PATH=
PLAYER_EMBEDDINGS_PATH=
PLAYER_METADATA_PATH=
PLAYER_DATA_PATH=

# Optional hosted frontend runtime injection
# Used by docker/nginx or any platform that writes assets/runtime-config.js at startup.
# Leave empty for local development if the frontend points directly to http://127.0.0.1:8000.
SCOUTING_FRONTEND_RUNTIME_CONFIG_PATH=

# Optional provider credentials
SPORTMONKS_API_TOKEN=
APIFOOTBALL_API_KEY=
ODDS_API_KEY=
RAPIDAPI_KEY=

# Optional experimental NLP configuration
HF_DEVICE=cpu
SUMMARIZATION_MODEL=facebook/bart-large-cnn
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
ZERO_SHOT_MODEL=facebook/bart-large-mnli
MAX_SUMMARY_TOKENS=180
ROLE_CONFIDENCE_THRESHOLD=0.55
ENABLE_ROLE_CLASSIFICATION=1
